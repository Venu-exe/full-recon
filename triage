#!/bin/bash

# ==========================================================
# Triage Helper -- run AFTER daily_recon.sh finishes
# Usage: ./triage.sh target.com
#
# Takes the huge gf_results/*.txt + urls/with_params.txt from
# daily_recon.sh and boils them down to a short, prioritized
# list of REAL example URLs worth manually testing in Burp --
# instead of scrolling thousands of near-duplicate lines.
#
# Output: triage/priority_list.txt  (read this one first)
# ==========================================================

set -uo pipefail

CYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RESET='\033[0m'

log()     { echo -e "\n${GREEN}[*]${RESET} $1"; }
warn()    { echo -e "${YELLOW}[!]${RESET} $1"; }
section() { echo -e "\n${CYAN}== $1 ==${RESET}"; }

if [ -z "${1:-}" ]; then
    echo "Usage: $0 <domain>"
    echo "Run this from the SAME parent directory you ran daily_recon.sh in."
    exit 1
fi

DOMAIN=$1
OUTDIR="recon_$DOMAIN"

if [ ! -d "$OUTDIR" ]; then
    echo "Can't find $OUTDIR -- run daily_recon.sh $DOMAIN first."
    exit 1
fi

cd "$OUTDIR" || exit 1
mkdir -p triage

# ----------------------------------------------------------
# Known analytics/tracking noise params -- always skip these,
# they show up in gf matches constantly but are essentially
# never exploitable (GA/GTM/AppsFlyer/UTM plumbing).
# ----------------------------------------------------------
NOISE_REGEX='^(af_|utm_|_c$|_ff$|_l$|_l10n$|_lrmc$|_plk$|_style$|_thumbnail_id$|_density$|cid$|ec$|ev$|ds$|v$|ver$|t$|tl$|hl$|pid$|pn$|pg$|mode$|format$|display$|key$|token$|campaign$|medium$|source$|srsltid$)'

REDIRECT_PARAMS="url new_url redirect_uri returnurl refURL linkurl share_url startURL canonicalUrl redirect return next dest continue target"
TEXT_PARAMS="q search keyword name text title address city comment message feedback review"
IDOR_PARAMS="hotel_id bookingId activityId cityId site_id siteId tierId id ID user_id account_id order_id booking_id reservation_id invoice_id"

: > triage/priority_list.txt

# ----------------------------------------------------------
# 1. OPEN REDIRECT / URL PARAMS  (highest value first)
# ----------------------------------------------------------
section "1. Open redirect / URL parameter candidates"
{
echo ""
echo "###############################################"
echo "# 1. OPEN REDIRECT CANDIDATES"
echo "# Test: swap the value for https://example.com"
echo "# and see if it actually redirects off-domain."
echo "###############################################"
} >> triage/priority_list.txt

FOUND_REDIRECT=0
for param in $REDIRECT_PARAMS; do
    echo "$param" | grep -qE "$NOISE_REGEX" && continue
    MATCH=$(grep -hoE "https?://[^\"' ]*[?&]${param}=[^&\"' ]*" \
        gf_results/redirect.txt urls/with_params.txt 2>/dev/null | sort -u | head -2)
    if [ -n "$MATCH" ]; then
        FOUND_REDIRECT=1
        echo -e "\n--- param: $param ---" >> triage/priority_list.txt
        echo "$MATCH" >> triage/priority_list.txt
        echo -e "${GREEN}[+]${RESET} $param: $(echo "$MATCH" | wc -l) example(s)"
    fi
done
[ "$FOUND_REDIRECT" -eq 0 ] && warn "No redirect-style params found with live examples"

# ----------------------------------------------------------
# 2. TEXT-REFLECTION PARAMS (XSS testing candidates)
# ----------------------------------------------------------
section "2. Text-reflection / XSS candidates"
{
echo ""
echo "###############################################"
echo "# 2. XSS / TEXT-REFLECTION CANDIDATES"
echo "# Test: replace value with a canary like"
echo "# XSSCANARY123<>\"'  then view-source and check"
echo "# if it comes back raw, encoded, or stripped."
echo "###############################################"
} >> triage/priority_list.txt

FOUND_XSS=0
for param in $TEXT_PARAMS; do
    echo "$param" | grep -qE "$NOISE_REGEX" && continue
    MATCH=$(grep -hoE "https?://[^\"' ]*[?&]${param}=[^&\"' ]*" \
        gf_results/xss.txt gf_results/comment-inject.txt urls/with_params.txt 2>/dev/null | sort -u | head -2)
    if [ -n "$MATCH" ]; then
        FOUND_XSS=1
        echo -e "\n--- param: $param ---" >> triage/priority_list.txt
        echo "$MATCH" >> triage/priority_list.txt
        echo -e "${GREEN}[+]${RESET} $param: $(echo "$MATCH" | wc -l) example(s)"
    fi
done
[ "$FOUND_XSS" -eq 0 ] && warn "No text-reflection params found with live examples"

# ----------------------------------------------------------
# 3. IDOR CANDIDATES
# ----------------------------------------------------------
section "3. IDOR candidates (ID-style params)"
{
echo ""
echo "###############################################"
echo "# 3. IDOR CANDIDATES"
echo "# Test: while logged in, change the ID value by"
echo "# +/-1 or +/-10 and see if you get someone else's"
echo "# data back using YOUR OWN session/token."
echo "###############################################"
} >> triage/priority_list.txt

FOUND_IDOR=0
for param in $IDOR_PARAMS; do
    echo "$param" | grep -qE "$NOISE_REGEX" && continue
    MATCH=$(grep -hoE "https?://[^\"' ]*[?&]${param}=[^&\"' ]*" \
        gf_results/idor.txt gf_results/idor-extended.txt urls/with_params.txt 2>/dev/null | sort -u | head -2)
    if [ -n "$MATCH" ]; then
        FOUND_IDOR=1
        echo -e "\n--- param: $param ---" >> triage/priority_list.txt
        echo "$MATCH" >> triage/priority_list.txt
        echo -e "${GREEN}[+]${RESET} $param: $(echo "$MATCH" | wc -l) example(s)"
    fi
done
[ "$FOUND_IDOR" -eq 0 ] && warn "No IDOR-style params found with live examples"

# ----------------------------------------------------------
# SUMMARY
# ----------------------------------------------------------
echo ""
echo -e "${CYAN}=========================================="
echo -e "${GREEN}[+]${RESET} Triage complete for $DOMAIN"
echo "=========================================="
echo "Read this file top to bottom, test in order:"
echo "  $OUTDIR/triage/priority_list.txt"
echo ""
echo "Sections are ordered by typical value:"
echo "  1. Open redirect  -> quick to test, clear yes/no"
echo "  2. XSS/reflection -> your proven workflow (canary + view-source)"
echo "  3. IDOR           -> highest impact if it hits, needs a real session"
echo ""
echo "Noise already stripped: af_*, utm_*, GA/GTM/analytics params"
echo -e "${CYAN}==========================================${RESET}"
